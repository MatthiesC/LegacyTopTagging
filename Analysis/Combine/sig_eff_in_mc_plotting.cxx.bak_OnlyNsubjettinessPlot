TGraph * new_null_graph() {
  int n = 1001; // should be the same number + 1 as the variable "nx" in analyze.py
  double x[n], y[n];
  for(int i = 0; i <= n; i++) {
    x[i] = i/double(n);
    y[i] = i/double(n);
  }
  TGraph * graph = new TGraph(n, x, y);
  graph->SetLineColorAlpha(kBlack, 0); // 0 = fully transparent
  return graph;
}



